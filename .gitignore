# Build output
**/bin/
**/obj/
publish_test/
/publish_stage_*/
/publish_noself/
/FastDOM/**/publish/

# publish/ is tracked — only exclude files containing credentials
publish/broker.schwab.json
publish/alpaca.json
publish/token.source.json
publish/logs/

# User secrets / credentials — block real credential filenames EVERYWHERE.
# The templates live under config-examples/ with `.example.` in the name so
# they don't collide with these rules. Never remove or un-ignore these lines.
**/appsettings.local.json
**/broker.schwab.json
**/alpaca.json
**/token.source.json
**/schwab.token.override.json

# Ephemeral python bridge scripts and DB2 side-car binaries stay local only
scripts/
FastDOM/FastDOM.App/rebuild/

# OS / IDE
.vs/
*.user
.DS_Store
Thumbs.db

# Logs
*.log
