<UserControl x:Class="FastDOM.App.Views.DepthMapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="#FF101010"
             Cursor="SizeNS"
             SizeChanged="OnSizeChanged"
             PreviewMouseLeftButtonDown="OnMouseLeftButtonDown"
             PreviewMouseMove="OnMouseMove"
             PreviewMouseLeftButtonUp="OnMouseLeftButtonUp">
    <DockPanel Background="#FF050707">
        <Border DockPanel.Dock="Top"
                Background="#FF070909"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,3">
            <DockPanel>
                <TextBlock Text="L2 HEAT"
                           DockPanel.Dock="Left"
                           FontSize="9"
                           FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="-"
                            Width="20"
                            Height="16"
                            Padding="0"
                            Margin="0,0,3,0"
                            Click="OnExpandClick"/>
                    <Button Content="&lt;&gt;"
                            Width="28"
                            Height="16"
                            Padding="0"
                            Margin="0,0,3,0"
                            Background="#FF335060"
                            Click="OnResetClick"/>
                    <Button Content="+"
                            Width="20"
                            Height="16"
                            Padding="0"
                            Margin="0,0,6,0"
                            Click="OnCompressClick"/>
                    <TextBlock Text="{Binding ScaleLabel}"
                               FontSize="9"
                               FontWeight="Bold"
                               Foreground="{StaticResource ForegroundBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                </StackPanel>
                <TextBlock Text="{Binding Status}"
                           FontSize="9"
                           TextAlignment="Right"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{StaticResource LastBrush}"/>
            </DockPanel>
        </Border>

        <Grid DockPanel.Dock="Top" Height="18" Background="#FF050505">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="58"/>
                <ColumnDefinition Width="62"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="LIQUIDITY HEAT" FontSize="9" FontWeight="Bold"
                       Foreground="{StaticResource SecondaryForeBrush}" TextAlignment="Left" VerticalAlignment="Center" Margin="8,0,0,0"/>
            <TextBlock Grid.Column="1" Text="PRICE" FontSize="9" FontWeight="Bold"
                       Foreground="{StaticResource ForegroundBrush}" TextAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="LIQ" FontSize="9" FontWeight="Bold"
                       Foreground="{StaticResource LastBrush}" TextAlignment="Left" VerticalAlignment="Center" Margin="3,0,0,0"/>
        </Grid>

        <Border x:Name="BookmapBody"
                Background="#FF030505"
                ClipToBounds="True">
            <ItemsControl ItemsSource="{Binding Rows}"
                          ClipToBounds="True">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Height="{Binding DataContext.RowHeight, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Background="#FF070909" ClipToBounds="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="58"/>
                                <ColumnDefinition Width="62"/>
                            </Grid.ColumnDefinitions>

                            <Rectangle Grid.Column="0" Grid.ColumnSpan="3"
                                       Height="1"
                                       VerticalAlignment="Top"
                                       Fill="#0818D7FF"/>
                            <Rectangle Grid.Column="0" Grid.ColumnSpan="3"
                                       Height="2"
                                       VerticalAlignment="Center"
                                       Fill="#FFFFD300"
                                       Opacity="0.95">
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCurrentPrice}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>

                            <Grid Grid.Column="0" ClipToBounds="True">
                                <Rectangle Fill="#FF051018"/>
                                <Rectangle HorizontalAlignment="Stretch"
                                           Height="{Binding DataContext.RowHeight, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                           VerticalAlignment="Center"
                                           Fill="#1019D9FF"/>
                                <Rectangle HorizontalAlignment="Stretch"
                                           Height="{Binding DataContext.RowHeight, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                           VerticalAlignment="Center"
                                           Fill="{Binding HeatBrush}"/>
                                <Rectangle HorizontalAlignment="Left"
                                           Width="{Binding HeatWidth}"
                                           Height="{Binding DataContext.RowHeight, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                           Fill="{Binding HeatBrush}"
                                           Opacity="0.82"/>
                                <Rectangle Width="1"
                                           HorizontalAlignment="Center"
                                           Fill="#6636B9FF"/>
                                <Rectangle Width="1"
                                           HorizontalAlignment="Left"
                                           Margin="44,0,0,0"
                                           Fill="#55FFFFFF"
                                           StrokeDashArray="2,4"/>
                                <Rectangle Width="1"
                                           HorizontalAlignment="Right"
                                           Margin="0,0,44,0"
                                           Fill="#55FFFFFF"
                                           StrokeDashArray="2,4"/>
                            </Grid>

                            <Border Grid.Column="1"
                                    Background="#FF050505"
                                    BorderBrush="#33202020"
                                    BorderThickness="1,0">
                                <TextBlock Text="{Binding PriceDisplay}"
                                           FontFamily="Consolas"
                                           FontSize="10"
                                           Foreground="#FFE8E8E8"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <Grid Grid.Column="2" Background="#FF050505" ClipToBounds="True">
                                <Rectangle HorizontalAlignment="Left"
                                           Width="4"
                                           Fill="{Binding SizeBrush}"
                                           Opacity="0.75"/>
                                <TextBlock Text="{Binding SizeDisplay}"
                                           FontFamily="Consolas"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           Foreground="{Binding SizeBrush}"
                                           TextAlignment="Left"
                                           VerticalAlignment="Center"
                                           Margin="7,0,0,0"/>
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </DockPanel>
</UserControl>
