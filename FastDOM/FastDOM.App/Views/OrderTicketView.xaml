<UserControl x:Class="FastDOM.App.Views.OrderTicketView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Background="{StaticResource PanelBrush}">
    <Border Padding="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
        <StackPanel>
            <TextBlock Text="ORDER TICKET" FontWeight="Bold" FontSize="11"
                       Foreground="{StaticResource SecondaryForeBrush}" Margin="0,0,0,6"/>

            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Side:" VerticalAlignment="Center" Foreground="{StaticResource SecondaryForeBrush}"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding OrderSides}"
                          SelectedItem="{Binding Side}" DisplayMemberPath="."/>
            </Grid>

            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Qty:" VerticalAlignment="Center" Foreground="{StaticResource SecondaryForeBrush}"/>
                <TextBox Grid.Column="1" Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Type:" VerticalAlignment="Center" Foreground="{StaticResource SecondaryForeBrush}"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding OrderTypes}" SelectedItem="{Binding OrderType}"
                          DisplayMemberPath="." />
            </Grid>

            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Limit:" VerticalAlignment="Center" Foreground="{StaticResource SecondaryForeBrush}"/>
                <TextBox Grid.Column="1" Text="{Binding LimitPrice, UpdateSourceTrigger=PropertyChanged, StringFormat=F2, TargetNullValue=''}"/>
            </Grid>

            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Stop:" VerticalAlignment="Center" Foreground="{StaticResource SecondaryForeBrush}"/>
                <TextBox Grid.Column="1" Text="{Binding StopPrice, UpdateSourceTrigger=PropertyChanged, StringFormat=F2, TargetNullValue=''}"/>
            </Grid>

            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="TIF:" VerticalAlignment="Center" Foreground="{StaticResource SecondaryForeBrush}"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding TifOptions}" SelectedItem="{Binding TimeInForce}"
                          DisplayMemberPath="."/>
            </Grid>

            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="SUBMIT" Margin="0,0,2,0"
                        Background="#FF1B5E20" Foreground="White" FontWeight="Bold"
                        Command="{Binding SubmitCommand}"/>
                <Button Grid.Column="1" Content="Clear" Margin="2,0,0,0"
                        Command="{Binding ClearCommand}"/>
            </Grid>

            <TextBlock Text="{Binding StatusMessage}" FontSize="11" TextWrapping="Wrap"
                       Foreground="{StaticResource AccentBrush}" Margin="0,2,0,4"/>

            <!-- Quick action buttons -->
            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,4,0,0">
                <StackPanel>
                    <!-- Buy row -->
                    <UniformGrid Rows="1" Columns="3" Margin="0,0,0,2">
                        <Button Content="Buy Mkt" Tag="BuyMarket"  Click="QuickAction_Click" Background="#1B5E20" Foreground="White" Margin="1" FontSize="10" Height="24"/>
                        <Button Content="Buy Ask" Tag="BuyAsk"     Click="QuickAction_Click" Background="#2E7D32" Foreground="White" Margin="1" FontSize="10" Height="24"/>
                        <Button Content="Buy Bid" Tag="BuyBid"     Click="QuickAction_Click" Background="#388E3C" Foreground="White" Margin="1" FontSize="10" Height="24"/>
                    </UniformGrid>
                    <!-- Sell row -->
                    <UniformGrid Rows="1" Columns="3" Margin="0,0,0,2">
                        <Button Content="Sell Mkt" Tag="SellMarket" Click="QuickAction_Click" Background="#B71C1C" Foreground="White" Margin="1" FontSize="10" Height="24"/>
                        <Button Content="Sell Ask" Tag="SellAsk"    Click="QuickAction_Click" Background="#D32F2F" Foreground="White" Margin="1" FontSize="10" Height="24"/>
                        <Button Content="Sell Bid" Tag="SellBid"    Click="QuickAction_Click" Background="#C62828" Foreground="White" Margin="1" FontSize="10" Height="24"/>
                    </UniformGrid>
                    <!-- Flatten + Cancel All -->
                    <UniformGrid Rows="1" Columns="2">
                        <Button Content="Flatten"    Tag="Flatten"   Click="QuickAction_Click" Background="#E65100" Foreground="White" Margin="1" FontSize="10" Height="24"/>
                        <Button Content="Cancel All" Tag="CancelAll" Click="QuickAction_Click" Background="#212121" Foreground="White" Margin="1" FontSize="10" Height="24"/>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
