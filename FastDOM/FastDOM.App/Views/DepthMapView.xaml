<UserControl x:Class="FastDOM.App.Views.DepthMapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FF070909"
             Focusable="True"
             SizeChanged="OnSizeChanged"
             PreviewMouseWheel="OnMouseWheel"
             PreviewMouseLeftButtonDown="OnMouseLeftButtonDown"
             PreviewMouseMove="OnMouseMove"
             PreviewMouseLeftButtonUp="OnMouseLeftButtonUp"
             LostMouseCapture="OnLostMouseCapture">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#FF101415" BorderBrush="#FF2A3336"
                BorderThickness="0,0,0,1" Padding="6,3">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="L2 HEAT" FontSize="11" FontWeight="Bold" Foreground="#FF4DD8FF"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1" Text="{Binding Status}" FontSize="9" Foreground="#FF9BA9AD"
                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                               ToolTip="{Binding Status}"/>
                </Grid>
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,3,0,0">
                    <TextBlock Text="BIN" Foreground="#FF7F8C90" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Button Content="−" Width="24" Height="22" Padding="0" Click="OnZoomInClick" ToolTip="Finer price bins"/>
                    <TextBlock Text="{Binding BinLabel}" Width="82" TextAlignment="Center"
                               FontWeight="Bold" Foreground="#FFFFDD55" VerticalAlignment="Center"/>
                    <Button Content="+" Width="24" Height="22" Padding="0" Click="OnZoomOutClick" ToolTip="Compress and aggregate prices"/>
                    <TextBlock Text="LEVELS" Foreground="#FF7F8C90" VerticalAlignment="Center" Margin="10,0,4,0"/>
                    <Button Content="−" Width="24" Height="22" Padding="0" Click="OnContractLevelsClick"/>
                    <TextBlock Text="{Binding LevelLabel}" Width="64" TextAlignment="Center"
                               FontWeight="Bold" Foreground="#FFE5E5E5" VerticalAlignment="Center"/>
                    <Button Content="+" Width="24" Height="22" Padding="0" Click="OnExpandLevelsClick"/>
                    <Button Content="RESET" Width="46" Height="22" Padding="0" Margin="10,0,0,0" Click="OnResetClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#FF101415" BorderBrush="#FF2A3336"
                BorderThickness="0,1,0,0" Padding="8,4">
            <Grid>
                <TextBlock Text="Wheel/drag to zoom"
                           Foreground="#FF829095" FontSize="9"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Visible liquidity " Foreground="#FF829095"/>
                    <TextBlock Text="{Binding VisibleLiquidity, StringFormat=N0}" Foreground="White" FontWeight="Bold"/>
                    <TextBlock Text="   Largest " Foreground="#FF829095"/>
                    <TextBlock Text="{Binding LargestOrder, StringFormat=N0}" Foreground="#FFFFDD55" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid DockPanel.Dock="Top" Height="24" Background="#FF050606">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="112"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="112"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="BID SIZE" Foreground="#FF5DE89B" FontWeight="Bold"
                       VerticalAlignment="Center" TextAlignment="Right" Margin="0,0,8,0"/>
            <TextBlock Grid.Column="2" Text="PRICE BIN" Foreground="#FFE5E5E5" FontWeight="Bold"
                       VerticalAlignment="Center" TextAlignment="Center"/>
            <TextBlock Grid.Column="4" Text="ASK SIZE" Foreground="#FFFF7777" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="8,0,0,0"/>
        </Grid>

        <Border x:Name="HeatBody" Background="#FF030404" ClipToBounds="True">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="True">
            <ItemsControl ItemsSource="{Binding Rows}" ClipToBounds="True">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Height="{Binding DataContext.RowHeight, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                              Background="{Binding HeatBrush}" ClipToBounds="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="112"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="112"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.ColumnSpan="5" BorderBrush="#151E282B" BorderThickness="0,0,0,1"/>

                            <Grid Grid.Column="0" Grid.ColumnSpan="2" ClipToBounds="True">
                                <Rectangle Width="{Binding BidWidth}" HorizontalAlignment="Right"
                                           Fill="{Binding BidBrush}"/>
                                <TextBlock Text="{Binding BidDisplay}" HorizontalAlignment="Right"
                                           VerticalAlignment="Center" Margin="0,0,8,0" FontFamily="Consolas"
                                           FontWeight="Bold" Foreground="#FF8CFFB5"/>
                            </Grid>

                            <Border Grid.Column="2" Background="#DD090B0C" BorderBrush="#FF2A3336" BorderThickness="1,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding PriceDisplay}" Foreground="{Binding PriceBrush}"
                                               FontFamily="Consolas" FontWeight="Bold"/>
                                    <TextBlock Text="  ●" Foreground="#FFFFDD33">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMarketPrice}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Grid Grid.Column="3" Grid.ColumnSpan="2" ClipToBounds="True">
                                <Rectangle Width="{Binding AskWidth}" HorizontalAlignment="Left"
                                           Fill="{Binding AskBrush}"/>
                                <TextBlock Text="{Binding AskDisplay}" HorizontalAlignment="Left"
                                           VerticalAlignment="Center" Margin="8,0,0,0" FontFamily="Consolas"
                                           FontWeight="Bold" Foreground="#FFFF9292"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0">
                                    <TextBlock Text="{Binding TotalDisplay}" Foreground="#FFEAEAEA" FontFamily="Consolas"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Concentration, StringFormat={} {0}}" Foreground="#FFFFDD33" FontSize="9"
                                               FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            </ScrollViewer>
        </Border>
    </DockPanel>
</UserControl>
