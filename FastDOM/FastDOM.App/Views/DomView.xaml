<UserControl x:Class="FastDOM.App.Views.DomView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:FastDOM.App.Converters"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:DomRowBrushConverter x:Key="RowBrush"/>
        <conv:OrderSummaryBrushConverter x:Key="OrderBrush"/>

        <Style x:Key="PriceCell" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <!-- DOM header -->
        <Border DockPanel.Dock="Top" Background="#FF0D0D0D" Padding="4,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="{Binding Symbol}" FontWeight="Bold" FontSize="14"
                               Foreground="{StaticResource AccentBrush}" Margin="0,0,8,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="−" Width="24" FontSize="11" Margin="2,0"
                            Command="{Binding DecreaseDepthCommand}"
                            ToolTip="Show fewer DOM price levels"/>
                    <TextBlock Text="{Binding VisibleLevels, StringFormat={}{0} lvls}"
                               Width="54"
                               FontFamily="Consolas"
                               FontSize="11"
                               Foreground="{StaticResource SecondaryForeBrush}"
                               TextAlignment="Center"
                               VerticalAlignment="Center"
                               ToolTip="Current DOM ladder depth"/>
                    <Button Content="+" Width="24" FontSize="11" Margin="2,0"
                            Command="{Binding IncreaseDepthCommand}"
                            ToolTip="Show more DOM price levels"/>
                    <Button Content="Z−" Width="30" FontSize="11" Margin="8,0,2,0"
                            Command="{Binding ZoomOutCommand}"
                            ToolTip="Zoom out: increase price step so the ladder covers more range"/>
                    <Button Content="&gt;&lt;" Width="30" FontSize="11" Margin="2,0"
                            Command="{Binding ResetZoomCommand}"
                            Background="#FF455A64"
                            Foreground="White"
                            FontWeight="Bold"
                            ToolTip="Reset DOM zoom to original 1-tick price step"/>
                    <Button Content="Z+" Width="30" FontSize="11" Margin="2,0,8,0"
                            Command="{Binding ZoomInCommand}"
                            ToolTip="Zoom in: decrease price step for finer ladder detail"/>
                    <Button Content="Lock" Width="50" FontSize="11" Margin="2,0"
                            Click="LockButton_Click"
                            ToolTip="Lock/follow the ladder around the last traded price"/>
                    <Button Content="Center" Width="55" FontSize="11" Margin="2,0"
                            ToolTip="Center ladder around last traded price"
                            Click="CenterButton_Click"/>
                    <CheckBox Content="Lock" IsChecked="{Binding IsLocked}"
                              ToolTip="Lock/follow last price"
                              VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DOM column headers -->
        <Grid DockPanel.Dock="Top" Background="#FF111111" Height="22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="70"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="86"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*" MinWidth="70"/>
                <ColumnDefinition Width="78"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="BUY" Style="{StaticResource PriceCell}"
                       Foreground="{StaticResource BuyOrderBrush}" FontWeight="Bold"/>
            <TextBlock Grid.Column="1" Text="BID" Style="{StaticResource PriceCell}"
                       Foreground="{StaticResource BidBrush}"/>
            <TextBlock Grid.Column="2" Text="PRICE" Style="{StaticResource PriceCell}"
                       FontWeight="Bold"/>
            <TextBlock Grid.Column="3" Text="ASK" Style="{StaticResource PriceCell}"
                       Foreground="{StaticResource AskBrush}"/>
            <TextBlock Grid.Column="4" Text="SELL" Style="{StaticResource PriceCell}"
                       Foreground="{StaticResource SellOrderBrush}" FontWeight="Bold"/>
            <TextBlock Grid.Column="5" Text="P/L" Style="{StaticResource PriceCell}"
                       Foreground="{StaticResource SecondaryForeBrush}" FontWeight="Bold"/>
            <!-- Column separator lines -->
            <Rectangle Grid.Column="1" Width="1" HorizontalAlignment="Left" Fill="#22FFFFFF" IsHitTestVisible="False"/>
            <Rectangle Grid.Column="2" Width="1" HorizontalAlignment="Left" Fill="#22FFFFFF" IsHitTestVisible="False"/>
            <Rectangle Grid.Column="3" Width="1" HorizontalAlignment="Left" Fill="#22FFFFFF" IsHitTestVisible="False"/>
            <Rectangle Grid.Column="4" Width="1" HorizontalAlignment="Left" Fill="#22FFFFFF" IsHitTestVisible="False"/>
            <Rectangle Grid.Column="5" Width="1" HorizontalAlignment="Left" Fill="#22FFFFFF" IsHitTestVisible="False"/>
            <!-- Header bottom line -->
            <Rectangle Grid.Column="0" Grid.ColumnSpan="6" Height="1" VerticalAlignment="Bottom" Fill="#22FFFFFF" IsHitTestVisible="False"/>
        </Grid>

        <!-- DOM price ladder -->
        <ScrollViewer x:Name="DomScroller" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="DomRows" ItemsSource="{Binding Rows}">
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid x:Name="DomRow" Height="18" Cursor="Hand"
                              MouseLeftButtonDown="DomRow_MouseLeftButtonDown"
                              MouseLeftButtonUp="DomRow_MouseLeftButtonUp"
                              MouseMove="DomRow_MouseMove"
                              MouseRightButtonDown="DomRow_MouseRightButtonDown">
                            <Grid.Background>
                                <MultiBinding Converter="{StaticResource RowBrush}">
                                    <Binding Path="IsBid"/>
                                    <Binding Path="IsAsk"/>
                                    <Binding Path="IsLast"/>
                                    <Binding Path="IsPosition"/>
                                </MultiBinding>
                            </Grid.Background>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="70"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="86"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*" MinWidth="70"/>
                                <ColumnDefinition Width="78"/>
                            </Grid.ColumnDefinitions>

                            <!-- Hover highlight: subtle overlay + top/bottom outline so the price
                                 you're about to click is unmistakable. Rendered UNDER content;
                                 non-hit-test so clicks reach the marker columns as before. -->
                            <Border Grid.Column="0" Grid.ColumnSpan="6"
                                    IsHitTestVisible="False"
                                    BorderThickness="0,1,0,1"
                                    Panel.ZIndex="-1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, ElementName=DomRow}" Value="True">
                                                <Setter Property="Background" Value="#33FFFFFF"/>
                                                <Setter Property="BorderBrush" Value="#88FFC107"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>

                            <!-- BUY orders at this price. Body of marker = drag zone. × on right edge = cancel. -->
                            <Grid Grid.Column="0" Margin="1">
                                <Border Background="{Binding BuyOrders.Count, Converter={StaticResource OrderBrush}, ConverterParameter=Buy}">
                                    <DockPanel Visibility="{Binding HasBuyOrders, Converter={StaticResource BoolToVisibility}}"
                                               LastChildFill="True">
                                        <Button DockPanel.Dock="Right" Content="×"
                                                Width="16" Height="18" Padding="0" Margin="1,0"
                                                FontSize="11" FontWeight="Bold"
                                                Background="#DD880000" Foreground="White" BorderThickness="0"
                                                Cursor="Hand"
                                                ToolTip="Cancel order(s) at this price"
                                                Tag="Buy"
                                                Click="OrderMarkerCancel_Click"/>
                                        <TextBlock Text="{Binding BuyOrderSummary}"
                                                   FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                                   Foreground="#FF90EE90"
                                                   TextAlignment="Center" VerticalAlignment="Center"
                                                   Cursor="SizeNS"
                                                   ToolTip="Drag up/down to move this order to a new price"/>
                                    </DockPanel>
                                </Border>
                                <!-- Live drag preview overlay: shows the drag ghost at the hovered row -->
                                <Border BorderBrush="#FFB2FF59" BorderThickness="2" CornerRadius="1"
                                        Background="#661B5E20" IsHitTestVisible="False">
                                    <Border.Visibility>
                                        <MultiBinding Converter="{StaticResource DragPreviewVis}" ConverterParameter="Buy">
                                            <Binding Path="Price"/>
                                            <Binding Path="DataContext.DragTargetPrice" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                            <Binding Path="DataContext.DragTargetSide"  RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                        </MultiBinding>
                                    </Border.Visibility>
                                    <TextBlock Text="{Binding DataContext.DragPreviewSummary, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                               Foreground="White"
                                               TextAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>

                            <!-- Bid size bar -->
                            <Grid Grid.Column="1">
                                <Rectangle HorizontalAlignment="Right"
                                           Width="{Binding BidSize, Converter={StaticResource SizeToWidthConverter}}"
                                           Fill="{StaticResource BidBrush}" Opacity="0.4" MaxWidth="58"/>
                                <TextBlock Text="{Binding BidSize}" Style="{StaticResource PriceCell}"
                                           Foreground="#FFEAF4FF"
                                           FontWeight="Bold"/>
                            </Grid>

                            <!-- Price column. Last trade is a narrow price marker, not a full row fill. -->
                            <Border Grid.Column="2">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLast}" Value="True">
                                                <Setter Property="Background" Value="#33251F00"/>
                                                <Setter Property="BorderBrush" Value="#FFFFD54F"/>
                                                <Setter Property="BorderThickness" Value="0,1,0,1"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Price, StringFormat=F2}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource PriceCell}">
                                            <Setter Property="FontWeight" Value="Normal"/>
                                            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLast}" Value="True">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="FontSize" Value="14"/>
                                                    <Setter Property="Foreground" Value="{StaticResource LastBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>

                            <!-- Ask size bar -->
                            <Grid Grid.Column="3">
                                <Rectangle HorizontalAlignment="Left"
                                           Width="{Binding AskSize, Converter={StaticResource SizeToWidthConverter}}"
                                           Fill="{StaticResource AskBrush}" Opacity="0.4" MaxWidth="58"/>
                                <TextBlock Text="{Binding AskSize}" Style="{StaticResource PriceCell}"
                                           Foreground="#FFFFECEA"
                                           FontWeight="Bold"/>
                            </Grid>

                            <!-- SELL orders at this price. × on left edge = cancel. Body = drag zone. -->
                            <Grid Grid.Column="4" Margin="1">
                                <Border Background="{Binding SellOrders.Count, Converter={StaticResource OrderBrush}, ConverterParameter=Sell}">
                                <DockPanel Visibility="{Binding HasSellOrders, Converter={StaticResource BoolToVisibility}}"
                                           LastChildFill="True">
                                    <Button DockPanel.Dock="Left" Content="×"
                                            Width="16" Height="18" Padding="0" Margin="1,0"
                                            FontSize="11" FontWeight="Bold"
                                            Background="#DD880000" Foreground="White" BorderThickness="0"
                                            Cursor="Hand"
                                            ToolTip="Cancel order(s) at this price"
                                            Tag="Sell"
                                            Click="OrderMarkerCancel_Click"/>
                                    <TextBlock Text="{Binding SellOrderSummary}"
                                               FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                               Foreground="#FFFF9090"
                                               TextAlignment="Center" VerticalAlignment="Center"
                                               Cursor="SizeNS"
                                               ToolTip="Drag up/down to move this order to a new price"/>
                                </DockPanel>
                                </Border>
                                <!-- Live drag preview overlay for sell side -->
                                <Border BorderBrush="#FFFF8A80" BorderThickness="2" CornerRadius="1"
                                        Background="#66B71C1C" IsHitTestVisible="False">
                                    <Border.Visibility>
                                        <MultiBinding Converter="{StaticResource DragPreviewVis}" ConverterParameter="Sell">
                                            <Binding Path="Price"/>
                                            <Binding Path="DataContext.DragTargetPrice" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                            <Binding Path="DataContext.DragTargetSide"  RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                        </MultiBinding>
                                    </Border.Visibility>
                                    <TextBlock Text="{Binding DataContext.DragPreviewSummary, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                               Foreground="White"
                                               TextAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>

                            <!-- Hypothetical position P/L at this price level -->
                            <TextBlock Grid.Column="5"
                                       Text="{Binding PriceLevelPnLDisplay}"
                                       Style="{StaticResource PriceCell}"
                                       FontSize="11"
                                       TextAlignment="Right"
                                       Padding="0,0,5,0"
                                       Foreground="{Binding PriceLevelPnL, Converter={StaticResource PnLBrushConverter}}"/>

                            <!-- Row grid line -->
                            <Rectangle Grid.Column="0" Grid.ColumnSpan="6"
                                       Height="1" VerticalAlignment="Bottom"
                                       Fill="#18FFFFFF" IsHitTestVisible="False"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
