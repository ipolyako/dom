<UserControl x:Class="FastDOM.App.Views.HotButtonsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Background="{StaticResource PanelBrush}">
    <DockPanel>
        <DockPanel DockPanel.Dock="Top" Background="#FF111111">
            <Button DockPanel.Dock="Right" Content="⚙" Width="24" Height="24"
                    FontSize="13" Padding="0" Margin="2"
                    ToolTip="Edit hot buttons"
                    Click="HotButtonSettings_Click"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{StaticResource SecondaryForeBrush}"
                    Cursor="Hand"/>
            <TextBlock Text="HOT BUTTONS" FontWeight="Bold"
                       FontSize="11" Padding="8,4"
                       Foreground="{StaticResource SecondaryForeBrush}"
                       VerticalAlignment="Center"/>
        </DockPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ScrollViewer.Resources>
                <DataTemplate x:Key="HotButtonTemplate">
                    <Button Height="30" Margin="2"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Content="{Binding Label}"
                            Background="{Binding Color}"
                            Foreground="{Binding TextColor}"
                            FontWeight="Bold" FontSize="11"
                            Click="HotButton_Click"
                            Tag="{Binding}"
                            IsEnabled="{Binding IsEnabled}"
                            ToolTip="{Binding KeyboardShortcut}"/>
                </DataTemplate>
            </ScrollViewer.Resources>
            <StackPanel Margin="4">
                <ItemsControl ItemsSource="{Binding EntryButtons}"
                              ItemTemplate="{StaticResource HotButtonTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><UniformGrid Columns="2"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <!-- Match the left order-ticket controls: Flatten and Cancel
                     are full-width, stacked, and immediately below entries. -->
                <ItemsControl ItemsSource="{Binding FullWidthButtons}"
                              ItemTemplate="{StaticResource HotButtonTemplate}"/>

                <ItemsControl ItemsSource="{Binding StrategyButtons}"
                              ItemTemplate="{StaticResource HotButtonTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><UniformGrid Columns="2"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
