<UserControl x:Class="FastDOM.App.Views.PositionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Background="{StaticResource PanelBrush}">

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
        <DockPanel>

            <!-- Section label -->
            <Border DockPanel.Dock="Top" Background="#FF161616" Padding="6,3"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <TextBlock Text="ACCOUNT POSITIONS" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource SecondaryForeBrush}"/>
            </Border>

            <!-- Column headers -->
            <Border DockPanel.Dock="Top" Background="#FF0D0D0D" Padding="3,2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="112"/>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="66"/>
                        <ColumnDefinition Width="66"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="SYM"      FontSize="10" Foreground="{StaticResource SecondaryForeBrush}" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="SHR"      FontSize="10" Foreground="{StaticResource SecondaryForeBrush}" FontWeight="Bold" TextAlignment="Right"/>
                    <TextBlock Grid.Column="2" Text="OPEN P/L" FontSize="10" Foreground="{StaticResource SecondaryForeBrush}" FontWeight="Bold" TextAlignment="Right" Margin="4,0"/>
                    <TextBlock Grid.Column="3" Text="DAY P/L"  FontSize="10" Foreground="{StaticResource SecondaryForeBrush}" FontWeight="Bold" TextAlignment="Right"/>
                </Grid>
            </Border>

            <!-- Position rows — each row is a button that loads the symbol into the DOM -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding AllPositions}" x:Name="PositionsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.SelectSymbolCommand,
                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding Symbol}"
                                    Background="Transparent" BorderThickness="0"
                                    HorizontalContentAlignment="Stretch"
                                    Padding="0" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bg" Background="Transparent"
                                                            BorderBrush="#FF1A1A1A" BorderThickness="0,0,0,1"
                                                            Padding="3,5">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="#FF1E1E1E"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="#FF252525"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="112"/>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="66"/>
                        <ColumnDefinition Width="66"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Symbol}"
                                               FontSize="10" FontWeight="Bold" FontFamily="Consolas"
                                               Foreground="{Binding Side, Converter={StaticResource SideBrushConverter}}"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Qty}"
                                               FontSize="10" FontFamily="Consolas"
                                               Foreground="{Binding Side, Converter={StaticResource SideBrushConverter}}"
                                               TextAlignment="Right"/>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding OpenPnL}"
                                               FontSize="10" FontFamily="Consolas"
                                               Foreground="{Binding OpenPnLValue, Converter={StaticResource PnLBrushConverter}}"
                                               TextAlignment="Right" Margin="4,0"/>

                                    <TextBlock Grid.Column="3"
                                               Text="{Binding DayPnL}"
                                               FontSize="10" FontFamily="Consolas"
                                               Foreground="{Binding DayPnLValue, Converter={StaticResource PnLBrushConverter}}"
                                               TextAlignment="Right"/>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.Template>
                        <ControlTemplate TargetType="ItemsControl">
                            <ItemsPresenter/>
                        </ControlTemplate>
                    </ItemsControl.Template>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>

