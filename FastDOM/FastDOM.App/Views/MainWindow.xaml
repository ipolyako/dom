<Window x:Class="FastDOM.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:FastDOM.App.Views"
        mc:Ignorable="d"
        Title="FastDOM — Execution Terminal"
        Height="870" Width="880"
        MinHeight="700" MinWidth="820"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource ForegroundBrush}"
        PreviewKeyDown="Window_KeyDown">

    <DockPanel>
        <!-- TOP BAR: Symbol, Mode, Connect, Quote -->
        <Border DockPanel.Dock="Top" Background="#FF0D0D0D" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Mode selector -->
                <ComboBox Grid.Column="0" Width="130" Margin="0,0,8,0"
                          ItemsSource="{Binding ModeOptions}"
                          SelectedItem="{Binding SelectedMode}"
                          DisplayMemberPath="Label"
                          ToolTip="Switch trading mode"/>

                <!-- Symbol input -->
                <TextBox Grid.Column="1" Width="90" x:Name="SymbolTextBox"
                         Text="{Binding SelectedSymbol, UpdateSourceTrigger=Explicit}"
                         KeyDown="SymbolTextBox_KeyDown"
                         GotKeyboardFocus="SymbolTextBox_GotKeyboardFocus"
                         PreviewMouseLeftButtonDown="SymbolTextBox_PreviewMouseLeftButtonDown"
                         FontFamily="Consolas" FontWeight="Bold" FontSize="13"
                         CharacterCasing="Upper"
                         VerticalContentAlignment="Center"
                         Margin="0,0,4,0"/>

                <!-- Account selector — border color reflects connection state -->
                <ComboBox Grid.Column="2" Width="160" Margin="0,0,8,0"
                          ItemsSource="{Binding Accounts}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="AccountId"
                          SelectedValue="{Binding SelectedAccountId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          BorderBrush="{Binding IsConnected, Converter={StaticResource ConnBrushConverter}}"
                          BorderThickness="2"
                          ToolTip="{Binding SelectedAccountId}"/>

                <!-- Buying power -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="12,0,0,0" ToolTip="{Binding BuyingPowerTooltip}">
                    <TextBlock Text="BP " Foreground="{StaticResource SecondaryForeBrush}"
                               FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding BuyingPowerDisplay}" FontSize="12" FontWeight="Bold"
                               Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Orders button — orange when open orders exist -->
                <Button Grid.Column="4" Content="Orders" Width="80" Margin="4,0"
                        Background="{Binding HasOpenOrders, Converter={StaticResource OrdersBrushConverter}}"
                        Click="OrdersButton_Click"
                        ToolTip="View and cancel open orders"/>

                <!-- Hotkeys armed indicator -->
                <Border Grid.Column="5" CornerRadius="3" Padding="6,2" Margin="4,0,0,0"
                        Background="{Binding HotkeysArmed, Converter={StaticResource HotkeyBrushConverter}}"
                        ToolTip="Click to toggle hotkeys" Cursor="Hand"
                        MouseLeftButtonUp="HotkeyIndicator_Click">
                    <TextBlock Text="{Binding HotkeysArmed, Converter={StaticResource HotkeyLabelConverter}}"
                               FontWeight="Bold" Foreground="White" FontSize="11"/>
                </Border>

                <!-- Hotkey settings button -->
                <Button Grid.Column="6" Content="⚙" Width="26" Height="26" Margin="2,0,0,0"
                        FontSize="14" Padding="0"
                        ToolTip="Configure hotkeys"
                        Click="HotkeySettings_Click"/>

                <!-- Options chain button -->
                <Button Grid.Column="7" Content="OPT" Width="40" Height="26" Margin="2,0,0,0"
                        FontSize="11" FontWeight="Bold" Padding="0"
                        ToolTip="Open options chain"
                        Click="OpenOptionsChain_Click"/>
            </Grid>
        </Border>

        <!-- BOTTOM: Activity log + toast -->
        <Border DockPanel.Dock="Bottom" Background="#FF0A0A0A" Height="140"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <DockPanel>
                <!-- Toast display -->
                <Border DockPanel.Dock="Top" Padding="8,2" Background="#FF161616">
                    <TextBlock Text="{Binding LastToast}" FontSize="12" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                </Border>

                <ListBox ItemsSource="{Binding ActivityLog}"
                         Background="Transparent" BorderThickness="0"
                         Foreground="{StaticResource SecondaryForeBrush}"
                         FontFamily="Consolas" FontSize="11"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         x:Name="ActivityListBox"/>
            </DockPanel>
        </Border>

        <!-- MAIN LAYOUT -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>   <!-- Position + Order ticket -->
                <ColumnDefinition Width="*"/>     <!-- DOM -->
                <ColumnDefinition Width="220"/>   <!-- Hot buttons -->
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL: Position + Order ticket + Emergency -->
            <Border Grid.Column="0" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel Background="{StaticResource PanelBrush}">

                <!-- Emergency kill switch -->
                <Border DockPanel.Dock="Bottom" Background="#FF300000" Padding="4">
                    <Button x:Name="KillSwitchButton"
                            Click="KillSwitch_Click"
                            Background="#FFDD0000" Foreground="White"
                            FontWeight="Bold" FontSize="14" Height="40"
                            Content="⚠ KILL SWITCH — CANCEL + FLATTEN"/>
                </Border>

<!-- Position panel — fixed height so the order ticket always has room -->
                <views:PositionView DockPanel.Dock="Top" DataContext="{Binding PositionViewModel}"
                                    Height="130"/>

                <!-- Share size -->
                <Border DockPanel.Dock="Top" Padding="8,4"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Size:" VerticalAlignment="Center" Width="35"/>
                        <TextBox Width="70" Text="{Binding ShareSize, UpdateSourceTrigger=PropertyChanged}"
                                 x:Name="ShareSizeBox"/>
                        <Button Content="100" Width="40" Margin="4,0,0,0"
                                Click="SizePreset_Click" Tag="100"/>
                        <Button Content="200" Width="40" Margin="2,0"
                                Click="SizePreset_Click" Tag="200"/>
                        <Button Content="500" Width="40"
                                Click="SizePreset_Click" Tag="500"/>
                    </StackPanel>
                </Border>

                <!-- Order ticket + quick action buttons -->
                <views:OrderTicketView DataContext="{Binding OrderTicketViewModel}"
                                       QuickAction="OnOrderTicketQuickAction"/>
            </DockPanel>
            </Border>

            <!-- CENTER: Position strip + DOM -->
            <DockPanel Grid.Column="1">

                <!-- Position summary strip above DOM -->
                <Border DockPanel.Dock="Top" Background="#FF111111" Padding="6,5"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                        DataContext="{Binding PositionViewModel}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Side + Qty -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                            <TextBlock Text="{Binding Side}" FontWeight="Bold" FontSize="13"
                                       Foreground="{Binding Side, Converter={StaticResource SideBrushConverter}}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text=" " FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Quantity}" FontSize="13" FontWeight="Bold"
                                       Foreground="{Binding Side, Converter={StaticResource SideBrushConverter}}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Avg cost -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0"
                                    Visibility="{Binding HasPosition, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="@" Foreground="{StaticResource SecondaryForeBrush}" FontSize="11" VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <TextBlock Text="{Binding AverageCost, StringFormat=F2}" FontSize="12"
                                       Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Unr. P&L (since open) -->
                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Unr " Foreground="{StaticResource SecondaryForeBrush}" FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding PnLDisplay}" FontSize="12" FontWeight="Bold"
                                       Foreground="{Binding UnrealizedPnL, Converter={StaticResource PnLBrushConverter}}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Separator -->
                        <TextBlock Grid.Column="4" Text="│" Foreground="{StaticResource SecondaryForeBrush}"
                                   FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                        <!-- Day P&L -->
                        <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Day " Foreground="{StaticResource SecondaryForeBrush}" FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding DayPnLDisplay}" FontSize="12" FontWeight="Bold"
                                       Foreground="{Binding DayPnL, Converter={StaticResource PnLBrushConverter}}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Quote strip — sits between position summary and DOM levels -->
                <Border DockPanel.Dock="Top" Background="#FF0A0A0A" Padding="6,3"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding QuoteDisplay}" FontSize="12" FontWeight="Bold"
                                   Foreground="{StaticResource LastBrush}" VerticalAlignment="Center"/>
                        <Border CornerRadius="3" Padding="4,1" Margin="8,0,0,0"
                                Background="{Binding MarketDataStale, Converter={StaticResource StaleBackgroundConverter}}">
                            <TextBlock Text="{Binding DataAgeDisplay}" FontSize="11"
                                       Foreground="{Binding MarketDataStale, Converter={StaticResource StaleForeConverter}}"/>
                        </Border>
                    </StackPanel>
                </Border>

                <views:DomView DataContext="{Binding DomViewModel}"
                               DomPriceLevelClicked="OnDomPriceLevelClicked"
                               DomContextMenuRequested="OnDomContextMenu"/>
            </DockPanel>

            <!-- RIGHT: Hot buttons + Watchlist -->
            <Border Grid.Column="2" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1,0,0,0">
                <DockPanel>
                    <!-- Watchlist: fixed height for ~10 symbols, docked to bottom -->
                    <Border DockPanel.Dock="Bottom" Height="270"
                            BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="0,1,0,0">
                        <views:WatchlistView DataContext="{Binding WatchlistViewModel}"/>
                    </Border>
                    <!-- Hot buttons fills remaining space -->
                    <views:HotButtonsView DataContext="{Binding HotButtonsViewModel}"
                                          HotButtonExecuted="OnHotButtonExecuted"
                                          HotButtonSettingsRequested="OnHotButtonSettingsRequested"/>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
