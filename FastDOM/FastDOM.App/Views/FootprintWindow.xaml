<Window x:Class="FastDOM.App.Views.FootprintWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:FastDOM.App.Views"
        Title="FastDOM Footprint" Width="1180" Height="820" MinWidth="720" MinHeight="480"
        Background="#080C0F" Foreground="White" WindowStartupLocation="CenterScreen">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#11181D" BorderBrush="#31404A" BorderThickness="0,0,0,1" Padding="8,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="SYMBOL" Foreground="#7F8C90" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="SymbolBox" Grid.Column="1" Background="#202A30" Foreground="#00C0FF"
                         FontFamily="Consolas" FontWeight="Bold" CharacterCasing="Upper"
                         GotKeyboardFocus="SymbolBox_GotKeyboardFocus"
                         PreviewMouseLeftButtonDown="SymbolBox_PreviewMouseLeftButtonDown"
                         KeyDown="SymbolBox_KeyDown"/>
                <TextBlock Grid.Column="2" Text="TIMEFRAME" Foreground="#7F8C90" VerticalAlignment="Center" Margin="14,0,6,0"/>
                <ComboBox x:Name="TimeframeBox" Grid.Column="3" SelectedIndex="0" SelectionChanged="TimeframeBox_SelectionChanged">
                    <ComboBoxItem Content="1 minute" Tag="1"/><ComboBoxItem Content="5 minutes" Tag="5"/>
                    <ComboBoxItem Content="15 minutes" Tag="15"/>
                </ComboBox>
                <TextBlock Grid.Column="4" Text="Estimated from Schwab conflated L1 trades • persisted in ROCH.FASTDOM_FOOTPRINT"
                           Foreground="#91A0A8" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBlock x:Name="StatusText" Grid.Column="5" Foreground="#FFD54F" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="6" Text="ZOOM" Foreground="#7F8C90" VerticalAlignment="Center" Margin="14,0,4,0"/>
                <Button Grid.Column="7" Content="−" Width="26" Padding="0" Click="ZoomOut_Click"/>
                <TextBlock x:Name="ZoomText" Grid.Column="8" Text="100%" Width="42" TextAlignment="Center"
                           VerticalAlignment="Center" Foreground="#D7E1E6"/>
                <Button Grid.Column="9" Content="+" Width="26" Padding="0" Click="ZoomIn_Click"/>
            </Grid>
        </Border>
        <ScrollViewer x:Name="ChartScroller" HorizontalScrollBarVisibility="Visible"
                      VerticalScrollBarVisibility="Visible" CanContentScroll="False"
                      PreviewMouseWheel="ChartScroller_PreviewMouseWheel">
            <views:FootprintChartControl x:Name="Chart"/>
        </ScrollViewer>
    </DockPanel>
</Window>
