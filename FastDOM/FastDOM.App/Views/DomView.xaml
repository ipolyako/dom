<UserControl x:Class="FastDOM.App.Views.DomView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:FastDOM.App.Converters"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:DomRowBrushConverter x:Key="RowBrush"/>
        <conv:OrderSummaryBrushConverter x:Key="OrderBrush"/>

        <!-- DOM row style — subtle highlight based on state -->
        <Style x:Key="DomRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Height" Value="20"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLast}" Value="True">
                    <Setter Property="Background" Value="#33FFD54F"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PriceCell" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <!-- DOM header -->
        <Border DockPanel.Dock="Top" Background="#FF0D0D0D" Padding="4,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="{Binding Symbol}" FontWeight="Bold" FontSize="14"
                               Foreground="{StaticResource AccentBrush}" Margin="0,0,8,0"/>
                    <Border Padding="4,1" CornerRadius="2" Background="#FF1B5E20"
                            Visibility="{Binding HasDepth, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="L2" FontSize="10" Foreground="LimeGreen"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="Lock" Width="50" FontSize="11" Margin="2,0"
                            Click="LockButton_Click"/>
                    <Button Content="Center" Width="55" FontSize="11" Margin="2,0"
                            Click="CenterButton_Click"/>
                    <CheckBox Content="Lock" IsChecked="{Binding IsLocked}"
                              VerticalAlignment="Center" Margin="4,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DOM column headers -->
        <Grid DockPanel.Dock="Top" Background="#FF111111" Height="22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="BUY" Style="{StaticResource PriceCell}"
                       Foreground="{StaticResource BuyOrderBrush}" FontWeight="Bold"/>
            <TextBlock Grid.Column="1" Text="BID" Style="{StaticResource PriceCell}"
                       Foreground="{StaticResource BidBrush}"/>
            <TextBlock Grid.Column="2" Text="PRICE" Style="{StaticResource PriceCell}"
                       FontWeight="Bold"/>
            <TextBlock Grid.Column="3" Text="ASK" Style="{StaticResource PriceCell}"
                       Foreground="{StaticResource AskBrush}"/>
            <TextBlock Grid.Column="4" Text="SELL" Style="{StaticResource PriceCell}"
                       Foreground="{StaticResource SellOrderBrush}" FontWeight="Bold"/>
            <!-- Column separator lines -->
            <Rectangle Grid.Column="1" Width="1" HorizontalAlignment="Left" Fill="#22FFFFFF" IsHitTestVisible="False"/>
            <Rectangle Grid.Column="2" Width="1" HorizontalAlignment="Left" Fill="#22FFFFFF" IsHitTestVisible="False"/>
            <Rectangle Grid.Column="3" Width="1" HorizontalAlignment="Left" Fill="#22FFFFFF" IsHitTestVisible="False"/>
            <Rectangle Grid.Column="4" Width="1" HorizontalAlignment="Left" Fill="#22FFFFFF" IsHitTestVisible="False"/>
            <!-- Header bottom line -->
            <Rectangle Grid.Column="0" Grid.ColumnSpan="5" Height="1" VerticalAlignment="Bottom" Fill="#22FFFFFF" IsHitTestVisible="False"/>
        </Grid>

        <!-- DOM price ladder -->
        <ScrollViewer x:Name="DomScroller" VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="DomRows" ItemsSource="{Binding Rows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid x:Name="DomRow" Height="20" Cursor="Hand"
                              MouseLeftButtonDown="DomRow_MouseLeftButtonDown"
                              MouseLeftButtonUp="DomRow_MouseLeftButtonUp"
                              MouseRightButtonDown="DomRow_MouseRightButtonDown">
                            <Grid.Background>
                                <MultiBinding Converter="{StaticResource RowBrush}">
                                    <Binding Path="IsBid"/>
                                    <Binding Path="IsAsk"/>
                                    <Binding Path="IsLast"/>
                                    <Binding Path="IsPosition"/>
                                </MultiBinding>
                            </Grid.Background>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>

                            <!-- BUY orders at this price. Body of marker = drag zone. × on right edge = cancel. -->
                            <Border Grid.Column="0"
                                    Background="{Binding BuyOrders.Count, Converter={StaticResource OrderBrush}, ConverterParameter=Buy}"
                                    Margin="1">
                                <DockPanel Visibility="{Binding HasBuyOrders, Converter={StaticResource BoolToVisibility}}"
                                           LastChildFill="True">
                                    <Button DockPanel.Dock="Right" Content="×"
                                            Width="16" Height="18" Padding="0" Margin="1,0"
                                            FontSize="11" FontWeight="Bold"
                                            Background="#DD880000" Foreground="White" BorderThickness="0"
                                            Cursor="Hand"
                                            ToolTip="Cancel order(s) at this price"
                                            Command="{Binding DataContext.CancelAtPriceCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Price}"/>
                                    <TextBlock Text="{Binding BuyOrderSummary}"
                                               FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                               Foreground="#FF90EE90"
                                               TextAlignment="Center" VerticalAlignment="Center"
                                               Cursor="SizeNS"
                                               ToolTip="Drag up/down to move this order to a new price"/>
                                </DockPanel>
                            </Border>

                            <!-- Bid size bar -->
                            <Grid Grid.Column="1">
                                <Rectangle HorizontalAlignment="Right"
                                           Width="{Binding BidSize, Converter={StaticResource SizeToWidthConverter}}"
                                           Fill="{StaticResource BidBrush}" Opacity="0.4" MaxWidth="58"/>
                                <TextBlock Text="{Binding BidSize}" Style="{StaticResource PriceCell}"
                                           Foreground="{StaticResource SecondaryForeBrush}"/>
                            </Grid>

                            <!-- Price column -->
                            <Border Grid.Column="2">
                                <TextBlock Text="{Binding Price, StringFormat=F2}" Style="{StaticResource PriceCell}"
                                           FontWeight="{Binding IsLast, Converter={StaticResource BoldConverter}}"/>
                            </Border>

                            <!-- Ask size bar -->
                            <Grid Grid.Column="3">
                                <Rectangle HorizontalAlignment="Left"
                                           Width="{Binding AskSize, Converter={StaticResource SizeToWidthConverter}}"
                                           Fill="{StaticResource AskBrush}" Opacity="0.4" MaxWidth="58"/>
                                <TextBlock Text="{Binding AskSize}" Style="{StaticResource PriceCell}"
                                           Foreground="{StaticResource SecondaryForeBrush}"/>
                            </Grid>

                            <!-- SELL orders at this price. × on left edge = cancel. Body = drag zone. -->
                            <Border Grid.Column="4"
                                    Background="{Binding SellOrders.Count, Converter={StaticResource OrderBrush}, ConverterParameter=Sell}"
                                    Margin="1">
                                <DockPanel Visibility="{Binding HasSellOrders, Converter={StaticResource BoolToVisibility}}"
                                           LastChildFill="True">
                                    <Button DockPanel.Dock="Left" Content="×"
                                            Width="16" Height="18" Padding="0" Margin="1,0"
                                            FontSize="11" FontWeight="Bold"
                                            Background="#DD880000" Foreground="White" BorderThickness="0"
                                            Cursor="Hand"
                                            ToolTip="Cancel order(s) at this price"
                                            Command="{Binding DataContext.CancelAtPriceCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Price}"/>
                                    <TextBlock Text="{Binding SellOrderSummary}"
                                               FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                               Foreground="#FFFF9090"
                                               TextAlignment="Center" VerticalAlignment="Center"
                                               Cursor="SizeNS"
                                               ToolTip="Drag up/down to move this order to a new price"/>
                                </DockPanel>
                            </Border>

                            <!-- Row grid line -->
                            <Rectangle Grid.Column="0" Grid.ColumnSpan="5"
                                       Height="1" VerticalAlignment="Bottom"
                                       Fill="#18FFFFFF" IsHitTestVisible="False"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
