<Window x:Class="FastDOM.App.Views.HotButtonSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hot Button Editor"
        Width="800" Height="700"
        MinWidth="640" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#FF1A1A1A"
        Foreground="#FFE0E0E0">

    <Window.Resources>
        <!-- Only window-specific resources here; all control styles come from DarkTheme.xaml -->
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </Window.Resources>

    <DockPanel Margin="10">

        <!-- ── Title bar ──────────────────────────────────────────────── -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <TextBlock Text="Hot Button Editor" FontSize="14" FontWeight="Bold"
                       Foreground="#FF00C0FF" VerticalAlignment="Center"/>
            <TextBlock Text="Select a row to edit its script"
                       FontSize="11" Foreground="#FF606060"
                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
        </DockPanel>

        <!-- ── Bottom toolbar ─────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="+ Add"     Width="68"  Margin="0,0,4,0"
                        Click="AddRow_Click" Background="#FF1A3A1A" BorderBrush="#FF2E7D32"/>
                <Button Grid.Column="1" Content="− Delete"  Width="76"  Margin="0,0,4,0"
                        Click="DeleteRow_Click" Background="#FF2A1010" BorderBrush="#FF7F0000"
                        x:Name="DeleteButton" IsEnabled="False"/>
                <Button Grid.Column="2" Content="↑ Up"      Width="50"  Margin="0,0,4,0"
                        Click="MoveUp_Click"   x:Name="MoveUpButton"   IsEnabled="False"/>
                <Button Grid.Column="3" Content="↓ Down"    Width="56"
                        Click="MoveDown_Click" x:Name="MoveDownButton" IsEnabled="False"/>
                <Button Grid.Column="5" Content="Reset Defaults" Width="108" Margin="0,0,8,0"
                        Click="ResetDefaults_Click" Background="#FF2A2A2A"/>
                <Button Grid.Column="6" Content="Cancel"    Width="78"  Margin="0,0,8,0"
                        Click="Cancel_Click"/>
                <Button Grid.Column="7" Content="Save"      Width="78"
                        Click="Save_Click" Background="#FF003870" BorderBrush="#FF0060C0"/>
            </Grid>
        </Border>

        <!-- ── Main content: grid + splitter + detail ─────────────────── -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="120"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="270" MinHeight="200"/>
            </Grid.RowDefinitions>

            <!-- ── Master DataGrid ─────────────────────────────────────── -->
            <DataGrid Grid.Row="0"
                      x:Name="ButtonsGrid"
                      ItemsSource="{Binding Edits}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      CanUserSortColumns="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      SelectionMode="Single"
                      ColumnHeaderHeight="24"
                      SelectionChanged="ButtonsGrid_SelectionChanged">

                <DataGrid.Columns>

                    <!-- Enabled -->
                    <DataGridCheckBoxColumn
                        Binding="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}"
                        Header="On" Width="36"/>

                    <!-- Label (editable inline) -->
                    <DataGridTemplateColumn Header="Label" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Label}" Padding="4,0" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Color swatch -->
                    <DataGridTemplateColumn Header="Color" Width="88">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                                    <Border Width="12" Height="12" CornerRadius="2" Margin="0,0,4,0"
                                            Background="{Binding ColorBrush}"/>
                                    <TextBlock Text="{Binding Color}" FontFamily="Consolas"
                                               FontSize="10" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Color, UpdateSourceTrigger=PropertyChanged}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Shortcut key -->
                    <DataGridTemplateColumn Header="Shortcut" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding KeyboardShortcut}" Padding="4,0"
                                           VerticalAlignment="Center" Foreground="#FF909090"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding KeyboardShortcut, UpdateSourceTrigger=PropertyChanged}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Script / Action preview -->
                    <DataGridTemplateColumn Header="Script / Action" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ScriptPreview}" Padding="6,0"
                                           VerticalAlignment="Center" FontFamily="Consolas"
                                           FontSize="11" TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>

            <!-- ── Grid splitter ──────────────────────────────────────── -->
            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                          Background="#FF2A2A2A" Cursor="SizeNS"/>

            <!-- ── Detail editor panel ─────────────────────────────────── -->
            <Border Grid.Row="2" Background="#FF161616"
                    BorderBrush="#FF333333" BorderThickness="0,1,0,0">
                <Grid>
                <!-- Placeholder when nothing selected -->
                <TextBlock x:Name="NoSelectionText"
                           Text="Select a button above to edit its script"
                           Foreground="#FF505050" FontStyle="Italic"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="Visible"/>

                <!-- Editor — shown when a row is selected -->
                <Grid x:Name="DetailGrid" Visibility="Collapsed" Margin="10,8,10,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto" MinHeight="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="*" MinHeight="60"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: basic metadata -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>

                        <Label Grid.Column="0"  Content="Label:"/>
                        <TextBox Grid.Column="1" x:Name="LabelBox"
                                 Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"/>

                        <Label Grid.Column="3"  Content="Color:"/>
                        <TextBox Grid.Column="4" x:Name="ColorBox"
                                 Text="{Binding Color, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas"/>

                        <Label Grid.Column="6"  Content="Key:"/>
                        <TextBox Grid.Column="7" x:Name="ShortcutBox"
                                 Text="{Binding KeyboardShortcut, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas" IsReadOnly="True"
                                 PreviewKeyDown="ShortcutBox_PreviewKeyDown"
                                 ToolTip="Click, then press any key combination to capture it. Backspace clears."/>

                        <Label Grid.Column="9"  Content="Enabled:"/>
                        <CheckBox Grid.Column="10" x:Name="EnabledBox"
                                  IsChecked="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}"
                                  VerticalAlignment="Center" Foreground="#FFE0E0E0"/>
                    </Grid>

                    <!-- Row 1: shortcut conflict warning -->
                    <TextBlock x:Name="ShortcutConflict" Grid.Row="1"
                               FontSize="10" FontFamily="Consolas"
                               Foreground="#FFFF9800" Visibility="Collapsed"
                               VerticalAlignment="Center" Margin="0,0,0,2"/>

                    <!-- Row 2: template picker -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Label Grid.Column="0" Content="Template:"/>
                        <ComboBox Grid.Column="1" x:Name="CategoryBox"
                                  SelectionChanged="CategoryBox_SelectionChanged"/>
                        <ComboBox Grid.Column="3" x:Name="TemplateBox"
                                  DisplayMemberPath="Name"
                                  ToolTip="{Binding SelectedItem.Description, RelativeSource={RelativeSource Self}}"/>
                        <Button Grid.Column="5" Content="Apply" Width="60"
                                Click="ApplyTemplate_Click"
                                Background="#FF003060" BorderBrush="#FF004A90"
                                ToolTip="Insert selected template into script below"/>
                    </Grid>

                    <!-- Row 4: script label -->
                    <DockPanel Grid.Row="4">
                        <TextBlock Text="Script" Foreground="#FF909090" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="(empty = use legacy Action)"
                                   Foreground="#FF505050" FontSize="10" FontStyle="Italic"
                                   VerticalAlignment="Center"/>
                        <Button DockPanel.Dock="Right" Content="Clear" Width="50" Height="20"
                                FontSize="10" Padding="0"
                                Click="ClearScript_Click"
                                Background="#FF2A1010" BorderBrush="#FF603030"/>
                    </DockPanel>

                    <!-- Row 6: script TextBox -->
                    <TextBox Grid.Row="6" x:Name="ScriptBox"
                             AcceptsReturn="True" AcceptsTab="False"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="12"
                             Background="#FF0E1E0E"
                             BorderBrush="#FF1A4A1A"
                             Text="{Binding Script, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Row 7: syntax quick-ref -->
                    <Expander Grid.Row="7" Header="Syntax Reference" Margin="0,4,0,0"
                              Foreground="#FF707070" IsExpanded="False">
                        <Border Background="#FF0A0A0A" Padding="6,4"
                                BorderBrush="#FF2A2A2A" BorderThickness="1">
                            <TextBlock FontFamily="Consolas" FontSize="10"
                                       Foreground="#FF909090" TextWrapping="Wrap">
                                <Run>BUY|SELL  SIZE|HALF|POS|PCT:N|$N|RISK:$N|N  MKT|LMT  ASK|BID|LAST|MID|ENTRY[±offset]</Run>
                                <LineBreak/>
                                <Run Foreground="#FF606060">          optional trailing: STOP ASK|BID|LAST|ENTRY±offset</Run>
                                <LineBreak/>
                                <Run>CANCEL  ALL|BUY|SELL        FLAT MKT        REVERSE MKT</Run>
                                <LineBreak/>
                                <Run>BRACKET STOP &lt;price&gt; [T1 &lt;price&gt;] [T2 &lt;price&gt;] [T3 &lt;price&gt;]</Run>
                                <LineBreak/>
                                <Run Foreground="#FF606060">          R-multiples in targets: ENTRY+1R, ENTRY+2R, ENTRY+3R  (1R = |entry − stop|)</Run>
                                <LineBreak/>
                                <Run Foreground="#FF606060">Examples: BUY SIZE LMT ASK   •   SELL HALF MKT   •   CANCEL ALL; BUY RISK:$100 LMT ASK STOP ASK-1.00</Run>
                            </TextBlock>
                        </Border>
                    </Expander>

                </Grid>
                </Grid>
            </Border>

        </Grid>
    </DockPanel>
</Window>
