<Window x:Class="FastDOM.App.Views.MoversWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FastDOM — Schwab Movers" Height="720" Width="1120" MinHeight="480" MinWidth="850"
        Background="{StaticResource BackgroundBrush}" Foreground="{StaticResource ForegroundBrush}">
    <Window.Resources>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#FF202020"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="#FF101010"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FF000000"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <DockPanel Margin="8">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="SCHWAB MARKET MOVERS" Foreground="{StaticResource AccentBrush}" FontSize="16" FontWeight="Bold"/>
                <TextBlock Text="{Binding Status}" Foreground="{StaticResource SecondaryForeBrush}" Margin="0,3,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="Refresh" Width="90" Height="30" Click="Refresh_Click"/>
        </Grid>
        <TabControl>
            <TabItem><TabItem.Header><TextBlock Text="TOP GAINERS" Foreground="Black" FontWeight="Bold"/></TabItem.Header><DataGrid ItemsSource="{Binding Gainers}" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" MouseDoubleClick="Grid_MouseDoubleClick"><DataGrid.Columns>
                <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" Width="85"/><DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="Price" Binding="{Binding LastPrice, StringFormat=N2}" Width="80"/><DataGridTextColumn Header="Yesterday Close" Binding="{Binding PreviousClose, StringFormat=N2}" Width="115"/><DataGridTextColumn Header="Change" Binding="{Binding NetChange, StringFormat=+0.00;-0.00;0.00}" Width="80"/>
                <DataGridTextColumn Header="Change %" Binding="{Binding NetPercentDisplay}" Width="85"/><DataGridTextColumn Header="Volume" Binding="{Binding Volume, StringFormat=N0}" Width="105"/>
                <DataGridTextColumn Header="Avg 10D Vol" Binding="{Binding Average10DayVolume, StringFormat=N0}" Width="110"/><DataGridTextColumn Header="Rel Vol" Binding="{Binding RelativeVolumeDisplay}" Width="75"/>
                <DataGridTextColumn Header="News" Binding="{Binding NewsDisplay}" Width="180"/>
            </DataGrid.Columns></DataGrid></TabItem>
            <TabItem><TabItem.Header><TextBlock Text="MOST ACTIVE" Foreground="Black" FontWeight="Bold"/></TabItem.Header><DataGrid ItemsSource="{Binding Active}" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" MouseDoubleClick="Grid_MouseDoubleClick" ColumnWidth="100"><DataGrid.Columns>
                <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}"/><DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/><DataGridTextColumn Header="Price" Binding="{Binding LastPrice, StringFormat=N2}"/><DataGridTextColumn Header="Yesterday Close" Binding="{Binding PreviousClose, StringFormat=N2}"/><DataGridTextColumn Header="Change %" Binding="{Binding NetPercentDisplay}"/><DataGridTextColumn Header="Volume" Binding="{Binding Volume, StringFormat=N0}"/><DataGridTextColumn Header="Avg 10D Vol" Binding="{Binding Average10DayVolume, StringFormat=N0}"/><DataGridTextColumn Header="Rel Vol" Binding="{Binding RelativeVolumeDisplay}"/><DataGridTextColumn Header="News" Binding="{Binding NewsDisplay}" Width="180"/>
            </DataGrid.Columns></DataGrid></TabItem>
            <TabItem><TabItem.Header><TextBlock Text="TOP LOSERS" Foreground="Black" FontWeight="Bold"/></TabItem.Header><DataGrid ItemsSource="{Binding Losers}" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" MouseDoubleClick="Grid_MouseDoubleClick" ColumnWidth="100"><DataGrid.Columns>
                <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}"/><DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/><DataGridTextColumn Header="Price" Binding="{Binding LastPrice, StringFormat=N2}"/><DataGridTextColumn Header="Yesterday Close" Binding="{Binding PreviousClose, StringFormat=N2}"/><DataGridTextColumn Header="Change" Binding="{Binding NetChange, StringFormat=+0.00;-0.00;0.00}"/><DataGridTextColumn Header="Change %" Binding="{Binding NetPercentDisplay}"/><DataGridTextColumn Header="Volume" Binding="{Binding Volume, StringFormat=N0}"/><DataGridTextColumn Header="Avg 10D Vol" Binding="{Binding Average10DayVolume, StringFormat=N0}"/><DataGridTextColumn Header="Rel Vol" Binding="{Binding RelativeVolumeDisplay}"/><DataGridTextColumn Header="News" Binding="{Binding NewsDisplay}" Width="180"/>
            </DataGrid.Columns></DataGrid></TabItem>
        </TabControl>
    </DockPanel>
</Window>
