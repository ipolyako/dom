<Window x:Class="FastDOM.App.Views.OptionsChainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Options Chain"
        Width="920" Height="620"
        MinWidth="760" MinHeight="440"
        WindowStartupLocation="CenterOwner"
        Background="#FF1A1A1A" Foreground="#FFE0E0E0"
        FontFamily="Consolas">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <!-- Named cell text styles for the options chain grid -->
        <!-- Call side: bright green for bid/ask, readable teal for IV/delta, gray for OI -->
        <Style x:Key="CallBidAsk" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="#FF4CAF50"/>
            <Setter Property="FontWeight"        Value="Bold"/>
            <Setter Property="TextAlignment"     Value="Right"/>
            <Setter Property="Padding"           Value="4,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor"            Value="Hand"/>
        </Style>
        <Style x:Key="CallCell" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="#FF80C8A0"/>
            <Setter Property="TextAlignment"     Value="Right"/>
            <Setter Property="Padding"           Value="4,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CallCellDim" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="#FF909090"/>
            <Setter Property="TextAlignment"     Value="Right"/>
            <Setter Property="Padding"           Value="4,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="StrikeCell" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="#FFE0E0E0"/>
            <Setter Property="FontWeight"        Value="Bold"/>
            <Setter Property="TextAlignment"     Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Put side: bright red for bid/ask, readable salmon for IV/delta, gray for OI -->
        <Style x:Key="PutBidAsk" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="#FFF44336"/>
            <Setter Property="FontWeight"        Value="Bold"/>
            <Setter Property="TextAlignment"     Value="Right"/>
            <Setter Property="Padding"           Value="4,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor"            Value="Hand"/>
        </Style>
        <Style x:Key="PutCell" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="#FFFF8A80"/>
            <Setter Property="TextAlignment"     Value="Right"/>
            <Setter Property="Padding"           Value="4,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="PutCellDim" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="#FF909090"/>
            <Setter Property="TextAlignment"     Value="Right"/>
            <Setter Property="Padding"           Value="4,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- ── Toolbar ─────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top" Background="#FF0D0D0D"
                BorderBrush="#FF3A3A3A" BorderThickness="0,0,0,1" Padding="8,6">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Symbol:" VerticalAlignment="Center"
                           Margin="0,0,6,0" Foreground="#FF909090"/>
                <TextBox x:Name="SymbolBox"
                         Text="{Binding Underlying, UpdateSourceTrigger=PropertyChanged}"
                         Width="80" CharacterCasing="Upper"
                         KeyDown="SymbolBox_KeyDown"/>
                <Button Content="Load Expiries" Margin="6,0,0,0"
                        Command="{Binding LoadExpirationsCommand}"/>

                <TextBlock Text="Expiry:" VerticalAlignment="Center"
                           Margin="16,0,6,0" Foreground="#FF909090"/>
                <ComboBox ItemsSource="{Binding Expirations}"
                          SelectedItem="{Binding SelectedExpiration}"
                          Width="110"/>
                <Button Content="Load Chain" Margin="6,0,16,0"
                        Command="{Binding LoadChainCommand}"
                        Background="#FF003870" BorderBrush="#FF0060C0"/>

                <TextBlock Text="Loading…" VerticalAlignment="Center"
                           Foreground="#FF2196F3" FontStyle="Italic"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolVis}}"/>

                <Button Content="✕ Close" Margin="16,0,0,0"
                        Background="#FF3A1A1A" BorderBrush="#FF7A3A3A"
                        Click="Close_Click"/>
            </WrapPanel>
        </Border>

        <!-- ── Bottom bar: selected contract + Add to Watchlist ─────── -->
        <Border DockPanel.Dock="Bottom" Background="#FF0D0D0D"
                BorderBrush="#FF3A3A3A" BorderThickness="0,1,0,0" Padding="8,5">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="Add to Watchlist" Margin="8,0,0,0"
                        Command="{Binding AddToWatchlistCommand}"
                        Background="#FF1B5E20" BorderBrush="#FF2E7D32"
                        Foreground="White" FontWeight="Bold"/>
                <TextBlock VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FF909090"/>
                            <Setter Property="Text"       Value="{Binding StatusMessage}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSelectedContract}"
                                             Value="True">
                                    <Setter Property="Foreground" Value="#FFFFD54F"/>
                                    <Setter Property="Text"       Value="{Binding SelectedContract.Display}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </DockPanel>
        </Border>

        <!-- ── CALLS / STRIKE / PUTS section header ─────────────────── -->
        <Grid DockPanel.Dock="Top" Background="#FF111111" Height="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="64"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="CALLS" FontWeight="Bold" FontSize="10"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="#FF4CAF50"/>
            <TextBlock Grid.Column="1" Text="STRIKE" FontWeight="Bold" FontSize="10"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="#FF909090"/>
            <TextBlock Grid.Column="2" Text="PUTS" FontWeight="Bold" FontSize="10"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="#FFF44336"/>
        </Grid>

        <!-- ── Chain DataGrid ────────────────────────────────────────── -->
        <DataGrid x:Name="ChainGrid"
                  ItemsSource="{Binding Rows}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  CanUserSortColumns="True"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  MouseLeftButtonUp="ChainGrid_MouseLeftButtonUp">

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                    <Setter Property="Height" Value="22"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCallItm}" Value="True">
                            <Setter Property="Background" Value="#FF182818"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <!-- CALLS (columns 0–4) -->
                <DataGridTextColumn Header="IV"    Width="52" Binding="{Binding CallIV}"
                                    ElementStyle="{StaticResource CallCell}"/>
                <DataGridTextColumn Header="Delta" Width="52" Binding="{Binding CallDelta}"
                                    ElementStyle="{StaticResource CallCell}"/>
                <DataGridTextColumn Header="OI"    Width="58" Binding="{Binding CallOI}"
                                    ElementStyle="{StaticResource CallCellDim}"/>
                <DataGridTextColumn Header="Bid"   Width="62" Binding="{Binding CallBid}"
                                    ElementStyle="{StaticResource CallBidAsk}"/>
                <DataGridTextColumn Header="Ask"   Width="62" Binding="{Binding CallAsk}"
                                    ElementStyle="{StaticResource CallBidAsk}"/>

                <!-- STRIKE (column 5) -->
                <DataGridTextColumn Header="Strike" Width="64" Binding="{Binding StrikeDisplay}"
                                    ElementStyle="{StaticResource StrikeCell}"/>

                <!-- PUTS (columns 6–10) -->
                <DataGridTextColumn Header="Bid"   Width="62" Binding="{Binding PutBid}"
                                    ElementStyle="{StaticResource PutBidAsk}"/>
                <DataGridTextColumn Header="Ask"   Width="62" Binding="{Binding PutAsk}"
                                    ElementStyle="{StaticResource PutBidAsk}"/>
                <DataGridTextColumn Header="OI"    Width="58" Binding="{Binding PutOI}"
                                    ElementStyle="{StaticResource PutCellDim}"/>
                <DataGridTextColumn Header="Delta" Width="52" Binding="{Binding PutDelta}"
                                    ElementStyle="{StaticResource PutCell}"/>
                <DataGridTextColumn Header="IV"    Width="52" Binding="{Binding PutIV}"
                                    ElementStyle="{StaticResource PutCell}"/>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>
