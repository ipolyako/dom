<Window x:Class="FastDOM.App.Views.HotkeySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:FastDOM.App.Converters"
        Title="Hotkey Configuration"
        Width="680" Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#FF1A1A1A"
        Foreground="#FFE0E0E0">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF303030"/>
            <Setter Property="Foreground" Value="#FFE0E0E0"/>
            <Setter Property="BorderBrush" Value="#FF505050"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF404040"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF252525"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="RowBackground" Value="#FF1E1E1E"/>
            <Setter Property="AlternatingRowBackground" Value="#FF222222"/>
            <Setter Property="Foreground" Value="#FFE0E0E0"/>
            <Setter Property="BorderBrush" Value="#FF333333"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#FF2A2A2A"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FF111111"/>
            <Setter Property="Foreground" Value="#FF909090"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#FF333333"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Height" Value="28"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFE0E0E0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF28384A"/>
                    <Setter Property="Foreground" Value="#FFE0E0E0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFE0E0E0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="12">
        <!-- Title + hint -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <TextBlock Text="Hotkey Bindings" FontSize="15" FontWeight="Bold"
                       Foreground="#FF00C0FF" VerticalAlignment="Center"/>
            <TextBlock Text="Click … to rebind a key, then press the new key combination"
                       FontSize="11" Foreground="#FF707070"
                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
        </DockPanel>

        <!-- Bottom buttons -->
        <Border DockPanel.Dock="Bottom" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Reset Defaults" Width="110"
                        Click="ResetDefaults_Click" Background="#FF2A2A2A"/>
                <Button Grid.Column="2" Content="Cancel" Width="80" Margin="0,0,8,0"
                        Click="Cancel_Click"/>
                <Button Grid.Column="3" Content="Save" Width="80"
                        Click="Save_Click" Background="#FF003870" BorderBrush="#FF0060C0"/>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <DataGrid x:Name="BindingsGrid"
                  ItemsSource="{Binding Edits}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  CanUserSortColumns="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  SelectionMode="Single"
                  ColumnHeaderHeight="26">

            <DataGrid.Columns>

                <!-- Enabled -->
                <DataGridCheckBoxColumn
                    Binding="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}"
                    Header="On" Width="38"/>

                <!-- Label -->
                <DataGridTextColumn
                    Binding="{Binding Label}"
                    Header="Action" Width="190" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="4,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDangerous}" Value="True">
                                    <Setter Property="Foreground" Value="#FFFF9090"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Key Gesture with rebind button -->
                <DataGridTemplateColumn Header="Key Gesture" Width="185">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Margin="2,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding GestureDisplay}"
                                           FontFamily="Consolas" FontSize="12"
                                           VerticalAlignment="Center" Padding="4,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#FFE0E0E0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRebinding}" Value="True">
                                                    <Setter Property="Foreground" Value="#FFFFCC00"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Button Grid.Column="1"
                                        Content="…" Height="20" Width="20" Padding="0"
                                        FontSize="11" Margin="1,0"
                                        Background="#FF2A2A2A" Foreground="#FFAAAAAA"
                                        BorderThickness="1" BorderBrush="#FF404040"
                                        Click="Rebind_Click"/>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Double press -->
                <DataGridCheckBoxColumn
                    Binding="{Binding RequireDoublePress, UpdateSourceTrigger=PropertyChanged}"
                    Header="2× Press" Width="64"/>

                <!-- Dangerous indicator -->
                <DataGridTemplateColumn Header="⚠" Width="36">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="⚠"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="#FFFF5555" FontSize="12"
                                       Visibility="{Binding IsDangerous, Converter={StaticResource BoolToVis}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
